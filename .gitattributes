# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Explicit source types
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.toml text eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf

# Binary files — never touch line endings
*.jar binary
*.webp binary
*.png binary
*.jpg binary
*.jks binary
